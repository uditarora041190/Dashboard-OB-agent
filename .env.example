# ─── Anthropic (for pre-call research analysis) ───────────────────────────────
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Vapi Credentials ─────────────────────────────────────────────────────────
# Get your API key from: https://dashboard.vapi.ai/account
VAPI_API_KEY=your_vapi_api_key_here

# The ID of the outbound phone number in your Vapi dashboard
# Dashboard → Phone Numbers → copy the ID of the number you want to call from
VAPI_PHONE_NUMBER_ID=your_phone_number_id_here

# (Optional) Set this if you already have an assistant ID and don't want to
# run setup_assistant.py again
VAPI_ASSISTANT_ID=

# ─── Call Settings ─────────────────────────────────────────────────────────────
# Seconds to wait between each call (default: 5)
CALL_DELAY_SECONDS=5
